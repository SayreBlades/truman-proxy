# Copy to .env and fill in your real keys.
# This file is read ONLY by the gateway container (never enters the agent).
# See .env.agent for the dummy keys the agent sees.

# Anthropic — Option 1: OAuth refresh token (recommended)
# Long-lived; gateway auto-refreshes short-lived access tokens.
# Get it: run `pi` locally, `/login` → Anthropic, then extract from ~/.pi/agent/auth.json
#   python3 -c "import json; print(json.load(open('$HOME/.pi/agent/auth.json'))['anthropic']['refresh'])"
ANTHROPIC_REFRESH_TOKEN=sk-ant-ort01-...

# Anthropic — Option 2: Static OAuth access token (expires in hours)
# ANTHROPIC_OAUTH_TOKEN=sk-ant-oat01-...

# Anthropic — Option 3: API key (doesn't expire, but requires paid API plan)
# ANTHROPIC_API_KEY=sk-ant-api03-...

BRAVE_API_KEY=BSAp-...
GH_TOKEN=ghp_...
